from __future__ import annotations

import json
import subprocess
from dataclasses import asdict, dataclass
from pathlib import Path

from PIL import Image, ImageDraw, ImageFont


ROOT = Path(__file__).resolve().parents[2]
SOURCE_PDF = ROOT / "${drawing_reference}"
OUT_DIR = ROOT / "src" / "viewer" / "assets" / "${asset_key}"
SOURCE_IMAGE = OUT_DIR / "source_page.png"


@dataclass(frozen=True)
class ViewSpec:
    key: str
    title: str
    subtitle: str
    crop: tuple[int, int, int, int]
    accent: str
    svg: str


def load_font(size: int = 24) -> ImageFont.ImageFont:
    candidates = [
        "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "C:/Windows/Fonts/arial.ttf",
        "C:/Windows/Fonts/segoeui.ttf",
        "C:/Windows/Fonts/msgothic.ttc",
    ]
    for path in candidates:
        if Path(path).exists():
            try:
                return ImageFont.truetype(path, size=size)
            except Exception:
                pass
    return ImageFont.load_default()


def render_pdf_preview() -> None:
    if not SOURCE_PDF.exists():
        raise FileNotFoundError(f"source pdf not found: {SOURCE_PDF}")

    OUT_DIR.mkdir(parents=True, exist_ok=True)
    command = [
        "convert",
        "-density",
        "180",
        f"{SOURCE_PDF}[0]",
        "-background",
        "white",
        "-alpha",
        "remove",
        str(SOURCE_IMAGE),
    ]
    subprocess.run(command, check=True)


def draw_label(
    draw: ImageDraw.ImageDraw,
    box: tuple[int, int, int, int],
    text: str,
    fill: str,
    font: ImageFont.ImageFont,
) -> None:
    x0, y0, x1, y1 = box
    draw.rounded_rectangle(box, radius=14, outline=fill, width=7)
    text_box = draw.textbbox((0, 0), text, font=font)
    width = text_box[2] - text_box[0]
    height = text_box[3] - text_box[1]
    tx = x0 + 16
    ty = max(16, y0 + 12)
    bg = (tx - 10, ty - 10, tx + width + 10, ty + height + 10)
    draw.rounded_rectangle(bg, radius=8, fill=(255, 255, 255))
    draw.text((tx, ty), text, fill=fill, font=font)


